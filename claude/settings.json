{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skillListingBudgetFraction": 0.03,
  "skillListingMaxDescChars": 512,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/hooks/node-hook-runner.sh .claude/statusline.cjs",
    "padding": 0
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/session-init.cjs"
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/usage-quota-cache-refresh.cjs",
            "timeout": 8
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/subagent-init.cjs"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/team-context-inject.cjs"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "Plan",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/cook-after-plan-reminder.cjs"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/session-state.cjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/dev-rules-reminder.cjs"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/simplify-gate.cjs"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/usage-quota-cache-refresh.cjs",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/descriptive-name.cjs"
          }
        ]
      },
      {
        "matcher": "Bash|Glob|Grep|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/scout-block.cjs"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/privacy-block.cjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/session-state.cjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|TaskCreate|TaskUpdate|TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/session-state.cjs"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/plan-format-kanban.cjs"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/node-hook-runner.sh .claude/hooks/usage-quota-cache-refresh.cjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
