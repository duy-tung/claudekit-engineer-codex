{
  "name": "claudekit-engineer",
  "version": "2.19.1",
  "description": "A lean, standard ClaudeKit for core software-engineering workflows with Claude Code.",
  "main": "index.js",
  "scripts": {
    "test": "node --test claude/hooks/__tests__/descriptive-name.test.cjs claude/hooks/__tests__/workflow-artifact-gate.test.cjs claude/skills/watzup/scripts/watzup-scan.test.cjs",
    "lint": "echo \"Linting passed\"",
    "verify": "bash init.sh",
    "eval:static": "python3 eval/tier0_static.py",
    "eval:audit": "python3 eval/audit_harness.py",
    "eval": "python3 eval/run.py --all",
    "eval:mock": "python3 eval/run.py --all --mock"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/duy-tung/claudekit-engineer-codex.git"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "development-template",
    "boilerplate",
    "automation",
    "cli-tools"
  ],
  "author": "Duy Nguyen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/duy-tung/claudekit-engineer-codex/issues"
  },
  "homepage": "https://github.com/duy-tung/claudekit-engineer-codex#readme",
  "claudekit": {
    "sourceDir": "claude",
    "runtimeDir": ".claude"
  },
  "files": [
    ".claude/",
    "plans/",
    "README.md",
    "LICENSE",
    ".claude/metadata.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
